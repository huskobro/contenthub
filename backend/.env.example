# ===========================================================================
# ContentHub — Environment Configuration
# ===========================================================================
# Bu dosyayi ".env" olarak kopyalayin ve degerleri doldurun.
# cp .env.example .env
#
# Oncelik sirasi: DB admin_value > .env > builtin default
# Admin panelden degistirilen ayarlar .env'i override eder.
# ===========================================================================

# ---------------------------------------------------------------------------
# ZORUNLU — Production'da mutlaka degistirilmeli
# ---------------------------------------------------------------------------

# JWT imzalama anahtari. Bos birakilirsa guvensiz dev fallback kullanilir.
# Production'da benzersiz, uzun bir secret set edin.
# Ornek: openssl rand -hex 32
CONTENTHUB_JWT_SECRET=

# Birincil LLM saglayici (Kie.ai / Gemini). Icerik uretimi icin zorunlu.
CONTENTHUB_KIE_AI_API_KEY=

# Gorsel saglayici (Pexels). Video gorselleri icin zorunlu.
CONTENTHUB_PEXELS_API_KEY=

# ---------------------------------------------------------------------------
# OPTIONAL — Bos birakilabilir, fallback mevcuttur
# ---------------------------------------------------------------------------

# Ikincil gorsel saglayici (Pixabay). Pexels bosalysa fallback olarak kullanilir.
CONTENTHUB_PIXABAY_API_KEY=

# Ikincil LLM saglayici (OpenAI uyumlu). Bos birakilirsa devre disi kalir.
CONTENTHUB_OPENAI_API_KEY=

# ---------------------------------------------------------------------------
# DEV-ONLY — Normal kullanim icin degistirmeye gerek yok
# ---------------------------------------------------------------------------

# Debug modu. true ise detayli log ciktisi verir.
# Production'da false birakin.
CONTENTHUB_DEBUG=false
