{
  "bulletinTitle": "Konsolosluk Çatışması, MacBook Neo Sızıntısı ve Albayrak",
  "items": [
    {
      "itemNumber": 1,
      "headline": "İstanbul İsrail Konsolosluğu Önünde Çatışma: Gözaltı Sayısı Ona Yükseldi",
      "narration": "İstanbul Beşiktaş'ta, İsrail Konsolosluğu'nun bulunduğu bina önünde dün silahlı bir çatışma yaşandı. Olay, güvenlik güçlerini harekete geçirdi. Geniş çaplı soruşturma hemen başlatıldı. Çatışmaya karıştığı düşünülen şüpheliler gözaltına alındı. Son bilgilere göre gözaltı sayısı ona yükseldi.",
      "audioPath": "http://127.0.0.1:60579/artifacts/audio/scene_1.mp3",
      "imagePath": "https://images.ntv.com.tr/images/israilkonsoloslukçatışma-690922.png",
      "imageTimeline": [
        {
          "url": "https://images.ntv.com.tr/images/israilkonsoloslukçatışma-690922.png",
          "startSeconds": 0.0,
          "durationSeconds": 23.568
        }
      ],
      "durationSeconds": 23.568,
      "category": null,
      "publishedAt": "2026-04-08T08:27:23",
