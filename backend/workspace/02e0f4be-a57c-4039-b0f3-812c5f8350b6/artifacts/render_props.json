      "sourceName": "NTV Gundem"
    },
    {
      "itemNumber": 7,
      "headline": "İznik Gölü'nde Su Seviyesi Endişe Veriyor",
      "narration": "Bursa'daki İznik Gölü'nde su seviyesi düşmeye devam ediyor. Göl yaklaşık üç yüz metre çekildi. Ülke genelinde barajlar yağışlarla dolarken. İznik Gölü'ndeki bu durum uzmanların dikkatini çekti. Su kaybının nedenleri araştırılıyor.",
      "audioPath": "http://127.0.0.1:54421/artifacts/audio/scene_7.mp3",
      "imagePath": "https://images.ntv.com.tr/images/AW678734_01-475892.jpg",
