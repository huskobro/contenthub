{
  "bulletinTitle": "Gündemden Son Dakika Haberler: TOKİ, Sel, Aile Katliamı",
  "items": [
    {
      "itemNumber": 1,
      "headline": "TOKİ İstanbul Kura Tarihi Belli Oldu",
      "narration": "Toplu Konut İdaresi Başkanlığı, İstanbul'da inşa edilecek yüz bin konutun kura çekimi tarihini duyurdu. Beş yüz bin sosyal konut projesi kapsamında gerçekleştirilecek. Bu çekilişle yüz bin konutun hak sahipleri belirlenecek. Detaylar önümüzdeki günlerde açıklanacak.",
      "audioPath": "http://127.0.0.1:54421/artifacts/audio/scene_1.mp3",
      "imagePath": "https://images.ntv.com.tr/images/image_1775625716910-650655.jpg",
      "imageTimeline": [
        {
          "url": "https://images.ntv.com.tr/images/image_1775625716910-650655.jpg",
          "startSeconds": 0.0,
          "durationSeconds": 20.88
        }
      ],
      "durationSeconds": 20.88,
      "category": null,
