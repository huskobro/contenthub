# macOS
.DS_Store
.AppleDouble
.LSOverride

# Python
__pycache__/
*.py[cod]
*.pyo
.pytest_cache/
.mypy_cache/
.ruff_cache/
.venv/
venv/
*.egg-info/
dist/
build/
*.egg

# Node
node_modules/
node_modules
**/node_modules
dist/
coverage/
.next/
out/

# Environment and secrets
.env
.env.*
!.env.example
*.pem
token.json
credentials.json
*.key
*.secret

# Local app data (root-level dev convenience dir)
data/*.db
data/*.db-shm
data/*.db-wal
data/*.sqlite
data/*.sqlite3

# Backend runtime database — SQLite DB, WAL journal, shared-memory files.
# These are runtime state, not source code. Clone starts with empty DB;
# run alembic upgrade head to initialize.
backend/data/*.db
backend/data/*.db-shm
backend/data/*.db-wal
backend/data/*.sqlite
backend/data/*.bak
backend/data/*.bak-shm
backend/data/*.bak-wal
backend/data/*.broken-*
backend/data/*.pre-*
# Keep .gitkeep so the directory exists after clone
!backend/data/.gitkeep

# Backend workspace — job artifacts (audio, video, JSON, subtitles, images).
# All content under backend/workspace/ is runtime output, not source code.
# Generated by the job engine; safe to delete and regenerate.
backend/workspace/**
!backend/workspace/.gitkeep

# Local runtime / workspace (root-level legacy stubs — kept for compat)
workspace/*
!workspace/jobs/
workspace/jobs/*
!workspace/jobs/.gitkeep
!workspace/exports/
workspace/exports/*
!workspace/exports/.gitkeep
!workspace/temp/
workspace/temp/*
!workspace/temp/.gitkeep
.tmp/

# Renderer test outputs
renderer/test-renders/

# Claude Code internal tooling — worktrees, session files
.claude/worktrees/
.claude/projects/

# Editor / system
.idea/
.vscode/
*.swp
*.swo
