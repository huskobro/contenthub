# macOS
.DS_Store
.AppleDouble
.LSOverride

# Python
__pycache__/
*.py[cod]
*.pyo
.pytest_cache/
.mypy_cache/
.ruff_cache/
.venv/
venv/
*.egg-info/
dist/
build/
*.egg

# Node
node_modules/
dist/
coverage/
.next/
out/

# Environment and secrets
.env
.env.*
!.env.example
*.pem
token.json
credentials.json
*.key
*.secret

# Local app data
data/*.db
data/*.sqlite
data/*.sqlite3

# Local runtime / workspace
# Ignore all runtime content but allow .gitkeep to track folder structure
workspace/*
!workspace/jobs/
workspace/jobs/*
!workspace/jobs/.gitkeep
!workspace/exports/
workspace/exports/*
!workspace/exports/.gitkeep
!workspace/temp/
workspace/temp/*
!workspace/temp/.gitkeep
.tmp/

# Editor / system
.idea/
.vscode/
*.swp
*.swo
